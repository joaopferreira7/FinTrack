# ════════════════════════════════════════════════════════════
# FinTrack — Variáveis de Ambiente
# ════════════════════════════════════════════════════════════
# Copie este arquivo para `.env` e configure os valores necessários.

# ✅ OBRIGATÓRIO: Chave secreta (use um valor aleatório longo)
SECRET_KEY=troque-por-uma-chave-secreta

# ⚠️ OPCIONAL: URL do banco de dados
# Padrão (desenvolvimento local): sqlite:///fintrack.db
# Produção (PostgreSQL): postgresql://user:password@localhost/fintrack
DATABASE_URL=sqlite:///fintrack.db

# ⚠️ OPCIONAL: Chave da API Groq (apenas se usar análise com IA)
# Deixe em branco para desativar IA; obtenha em https://console.groq.com
GROQ_API_KEY=
